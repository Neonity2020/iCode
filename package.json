{
  "name": "icode",
  "productName": "iCode",
  "version": "0.1.0",
  "description": "One Project. Multiple Coding Agents.",
  "main": ".vite/build/main.js",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "lint": "eslint .",
    "typecheck": "bun run typecheck:shared && bun run typecheck:main && bun run typecheck:preload && bun run typecheck:renderer",
    "typecheck:shared": "cd packages/shared && bun run typecheck",
    "typecheck:main": "cd packages/main && bun run typecheck",
    "typecheck:preload": "cd packages/preload && bun run typecheck",
    "typecheck:renderer": "cd packages/renderer && bun run typecheck",
    "build:shared": "cd packages/shared && bun run build"
  },
  "dependencies": {
    "electron-squirrel-startup": "1.0.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/maker-deb": "7.11.2",
    "@electron-forge/maker-dmg": "7.11.2",
    "@electron-forge/maker-rpm": "7.11.2",
    "@electron-forge/maker-squirrel": "7.11.2",
    "@electron-forge/maker-zip": "7.11.2",
    "@electron-forge/plugin-vite": "7.11.2",
    "@eslint/js": "9.39.1",
    "@types/node": "25.9.3",
    "@vitejs/plugin-react": "4.7.0",
    "electron": "31.7.7",
    "eslint": "9.39.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.6.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.50.1",
    "vite": "5.4.21"
  }
}
