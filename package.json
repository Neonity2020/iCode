{
  "name": "icode",
  "version": "0.0.0",
  "private": true,
  "description": "A focused desktop workspace for coding with agents",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vp dev",
    "check": "vp check",
    "build": "vp check && vp build",
    "preview": "vp preview",
    "start": "electron .",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "lucide-react": "^0.468.0",
    "node-pty": "^1.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^40.0.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.0",
    "vite-plus": "^0.2.1"
  },
  "optionalDependencies": {
    "@oxfmt/binding-darwin-arm64": "0.55.0",
    "@oxlint/binding-darwin-arm64": "1.70.0",
    "@rolldown/binding-darwin-arm64": "1.0.3",
    "@voidzero-dev/vite-plus-darwin-arm64": "0.2.1"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.8.0",
      "onFail": "download"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "node-pty"
    ]
  }
}
