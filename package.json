{
  "name": "icode-monorepo",
  "version": "0.1.0",
  "description": "One Project. Multiple Coding Agents.",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/desktop dev",
    "package": "bun run --cwd apps/desktop package",
    "make": "bun run --cwd apps/desktop make",
    "lint": "eslint .",
    "typecheck": "bun run typecheck:shared && bun run typecheck:desktop",
    "typecheck:shared": "cd packages/shared && bun run typecheck",
    "typecheck:desktop": "bun run --cwd apps/desktop typecheck",
    "build:shared": "cd packages/shared && bun run build"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@types/node": "25.9.3",
    "eslint": "9.39.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.6.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.50.1",
    "vite": "5.4.21"
  }
}
