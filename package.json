{
  "name": "icode",
  "version": "0.0.0",
  "private": true,
  "description": "iCode desktop and web workspace",
  "type": "module",
  "scripts": {
    "dev": "node apps/desktop/dev.mjs",
    "dev:desktop": "node apps/desktop/dev.mjs",
    "dev:web": "node scripts/run-app.mjs web dev",
    "check": "vp check && tsc -p packages/app/tsconfig.json && tsc -p apps/desktop/tsconfig.json && tsc -p apps/web/tsconfig.json",
    "build": "vp check && tsc -p packages/app/tsconfig.json && tsc -p apps/desktop/tsconfig.json && tsc -p apps/web/tsconfig.json && node scripts/run-app.mjs desktop build && node scripts/run-app.mjs web build",
    "build:desktop": "node scripts/run-app.mjs desktop build",
    "build:web": "node scripts/run-app.mjs web build",
    "preview:web": "node scripts/run-app.mjs web preview",
    "start": "node scripts/run-app.mjs desktop start"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^40.0.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.0",
    "vite-plus": "^0.2.1"
  },
  "optionalDependencies": {
    "@oxfmt/binding-darwin-arm64": "0.55.0",
    "@oxlint/binding-darwin-arm64": "1.70.0",
    "@rolldown/binding-darwin-arm64": "1.0.3",
    "@voidzero-dev/vite-plus-darwin-arm64": "0.2.1"
  },
  "packageManager": "pnpm@11.8.0"
}
